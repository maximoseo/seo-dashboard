# SEO Dashboard Environment Variables
# Copy to .env for local development, set as env vars in Vercel/Render for production.
# Never commit real values.

DASHBOARD_AUTH_USERNAME=service@example.com
DASHBOARD_AUTH_PASSWORD=change_me
DASHBOARD_AUTH_SECRET=generate_a_long_random_secret
DASHBOARD_TOKEN_TTL_SECONDS=43200
DASHBOARD_API_KEY=optional_machine_to_machine_token
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Durable portfolio spine writes/reads — never expose to browser
SUPABASE_SERVICE_ROLE=
# aliases accepted by server: SUPABASE_SERVICE_KEY, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_MCP_SERVICE_ROLE
AUTH_DISABLED=false
FRONTEND_URL=https://seo-dashboard.maximo-seo.ai

# Optional bridges (soft-fail when missing)
TODO_API_KEY=
TODO_API_BASE_URL=https://to-do-tasks.maximo-seo.ai
TODO_DEFAULT_PROJECT_ID=
ASANA_ACCESS_TOKEN=
ASANA_SEO_PROJECT_GID=
ASANA_WORKSPACE_GID=

AHREFS_API_KEY=your_ahrefs_api_key
SEMRUSH_API=your_semrush_api_key
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password
PAGESPEED_API_KEY=your_pagespeed_api_key
GTMETRIX_API=your_gtmetrix_api_key
GTMETRIX_EMAIL=your_gtmetrix_email
SE_RANKING_API=your_seranking_api_key
EXA_API_KEY=your_exa_api_key
BROWSERLESS_API_KEY=your_browserless_api_key
THORBIT_API_KEY=your_thorbit_api_key
PORT=3001
NODE_ENV=development
